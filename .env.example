# Copy this file to ".env" and fill in your real values.
# Never commit your real .env file to version control.

# Your secret OpenAI API key (get one at https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_api_key_here

# Which model to use (optional). gpt-4o-mini is fast and low-cost.
OPENAI_MODEL=gpt-4o-mini

# Port the server runs on (optional)
PORT=3000

# Optional: Google Cloud API key for Text-to-Speech + Translation (all languages).
# In Google Cloud Console enable "Cloud Text-to-Speech API" and "Cloud Translation API".
# Free tier: ~1M TTS characters/month; translation has its own free tier.
# Leave blank to use only browser voices (English accents from your system).
GOOGLE_CLOUD_TTS_API_KEY=
