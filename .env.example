# Copy this file to ".env" and fill in your real values.
# Never commit your real .env file to version control.

# Your secret OpenAI API key (get one at https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_api_key_here

# Which model to use (optional). gpt-4o-mini is fast and low-cost.
OPENAI_MODEL=gpt-4o-mini

# Port the server runs on (optional)
PORT=3000

# Optional: Google Cloud Text-to-Speech API key for Punjabi + English voices.
# Enable "Cloud Text-to-Speech API" in Google Cloud Console, then create an API key.
# Free tier: ~1 million characters/month. Leave blank to use only browser voices.
GOOGLE_CLOUD_TTS_API_KEY=
