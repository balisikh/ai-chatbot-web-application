# Copy this file to ".env" and fill in your real values.
# Never commit your real .env file to version control.

# --- AI provider (pick one or both) ---

# OpenAI (optional — paid cloud AI)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ollama (optional — free local AI, default when running)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# If C: drive is tight, point Ollama models to another drive (Windows example):
# OLLAMA_MODELS=D:\ollama\models

# --- Server ---

PORT=3000

# --- Google Cloud (optional — all language voices + translation) ---

# One API key powers BOTH Cloud Text-to-Speech and Cloud Translation.
# Setup guide: docs/GOOGLE_CLOUD_SETUP.md
#
# 1. Create a project at https://console.cloud.google.com
# 2. Enable "Cloud Text-to-Speech API" and "Cloud Translation API"
# 3. APIs & Services → Credentials → Create API key
# 4. Paste the key below and restart the server (npm start)
#
# Leave blank to use browser voices only (no Google translation).
GOOGLE_CLOUD_TTS_API_KEY=
